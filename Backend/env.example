# ── StudyFlow Backend — Variáveis de ambiente ──────────────────────────────
# Copia este ficheiro para Backend/.env, preenche os valores e nunca o cometas ao Git.

# Firebase Web API Key
# Firebase Console → Definições do projeto → Geral → Chave de API da Web
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Caminho para o ficheiro serviceAccountKey.json (relativo à raiz do Backend)
# Firebase Console → Definições do projeto → Contas de serviço → Gerar nova chave privada
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
# Alternativa ao ficheiro: cola o JSON inline aqui (útil em containers/CI)
# FIREBASE_SERVICE_ACCOUNT_JSON=

GROQ_API_KEY=your_groq_api_key

# ── Resend ─────────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_verified_sender@example.com

DEBUG=False
